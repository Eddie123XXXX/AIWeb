# Docker Compose production variables
# Copy to deploy/.env.prod and replace every placeholder before first startup.

COMPOSE_PROJECT_NAME=aiweb

POSTGRES_USER=aiweb
POSTGRES_PASSWORD=replace-with-a-strong-postgres-password
POSTGRES_DB=aiweb
POSTGRES_PORT=5432

REDIS_PASSWORD=replace-with-a-strong-redis-password
REDIS_PORT=6379

MINIO_ROOT_USER=replace-with-a-minio-access-key
MINIO_ROOT_PASSWORD=replace-with-a-minio-secret
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

MILVUS_GRPC_PORT=19530
MILVUS_HTTP_PORT=9091
