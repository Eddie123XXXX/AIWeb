# Production backend environment for AIWeb
# Copy to backend/.env.production or backend/.env on the server and fill in real secrets.

# Runtime
HOST=127.0.0.1
PORT=8000
DEBUG=false
# Comma-separated frontend origins allowed to call the API.
ALLOWED_ORIGINS=https://ai.example.com,https://www.ai.example.com
# Optional regex when you need wildcard subdomains.
# CORS_ALLOW_ORIGIN_REGEX=https://.*\.example\.com

# Authentication
JWT_SECRET=replace-with-a-random-32-plus-char-secret
JWT_ALGORITHM=HS256
JWT_EXPIRE_SECONDS=86400

# PostgreSQL
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432
POSTGRES_USER=aiweb
POSTGRES_PASSWORD=replace-with-a-strong-postgres-password
POSTGRES_DB=aiweb

# Redis
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=replace-with-a-strong-redis-password

# MinIO
MINIO_ENDPOINT=127.0.0.1:9000
MINIO_ACCESS_KEY=replace-with-a-minio-access-key
MINIO_SECRET_KEY=replace-with-a-minio-secret
MINIO_BUCKET=aiweb
MINIO_SECURE=false

# Milvus
MILVUS_HOST=127.0.0.1
MILVUS_PORT=19530

# At least one chat model API key is required.
# OPENAI_API_KEY=
# OPENAI_API_BASE=https://api.openai.com/v1
# DEEPSEEK_API_KEY=
# DEEPSEEK_API_BASE=https://api.deepseek.com/v1
# QWEN_API_KEY=
# QWEN_API_BASE=https://dashscope.aliyuncs.com/compatible-mode/v1
# ANTHROPIC_API_KEY=
# MOONSHOT_API_KEY=
# ZHIPU_API_KEY=
# GEMINI_API_KEY=

# Optional default model override
# DEFAULT_MODEL_ID=default
# DEFAULT_MODEL_NAME=DeepSeek Chat
# DEFAULT_MODEL_PROVIDER=deepseek
# DEFAULT_MODEL_MODEL_NAME=deepseek-chat
# DEFAULT_MODEL_API_KEY=
# DEFAULT_MODEL_API_BASE=
# DEFAULT_MODEL_MAX_TOKENS=8192
# DEFAULT_MODEL_TEMPERATURE=0.7

# Search / Agentic
# SERPER_API_KEY=
# SERPER_SEARCH_URL=https://google.serper.dev/search
# BOCHA_API_KEY=
# BOCHA_APISEARCH_URL=https://api.bochaai.com/v1/web-search
# MCP_SERVERS_JSON=

# Memory / RAG recommended keys
# MEMORY_EMBEDDING_MODEL=text-embedding-v4
# MEMORY_EMBEDDING_DIM=1536
# MEMORY_SCORER_MODEL=deepseek-chat
# QWEN_API_KEY=
# DEEPSEEK_API_KEY=

# RAG parsing and reranking
# JINA_API_KEY=
# RAG_USE_QUEUE=false
# RAG_EMBEDDING_MODEL=text-embedding-v4
# RAG_EMBEDDING_DIM=1536
# RAG_MAX_EMBEDDING_TOKENS=2048
# MINERU_EXTERNAL_API_BASE_URL=https://mineru.net
# MINERU_API_TOKEN=
# MINERU_EXTERNAL_MODEL_VERSION=
# MINERU_API_BASE_URL=http://127.0.0.1:9999
# MINERU_BACKEND=pipeline
# MINIO_PUBLIC_ENDPOINT=

# ASR
# DASHSCOPE_API_KEY=
# DASHSCOPE_API_BASE=https://dashscope.aliyuncs.com/compatible-mode/v1
