# Production frontend environment for AIWeb

# Recommended for same-domain deployment behind Nginx:
# keep VITE_API_BASE empty so the browser uses the current origin and Nginx forwards /api.
# VITE_API_BASE=

# If frontend and backend use different domains, uncomment and point to your API origin:
# VITE_API_BASE=https://api.example.com

# Optional brand logo integration
# VITE_BRANDFETCH_CLIENT_ID=
